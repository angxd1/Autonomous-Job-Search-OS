# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Clerk (https://clerk.com) -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=whsec_xxx

# ----- Supabase / Postgres (https://supabase.com) -----
# DATABASE_URL is the pooled connection (port 6543) used at runtime.
# DIRECT_URL is the direct connection (port 5432) used by Prisma migrations.
DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Supabase service role for server-side storage (optional until Phase 4)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# ----- OpenAI (https://platform.openai.com) -----
OPENAI_API_KEY=sk-xxx

# ----- Inngest (https://www.inngest.com) -----
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=signkey-xxx

# ----- Resend Inbound (https://resend.com) -----
RESEND_API_KEY=re_xxx
RESEND_INBOUND_SECRET=xxx

# ----- Encryption (for BYO-OpenAI-key feature) -----
# 32+ character random string. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-32-byte-random-string!

# ----- Extension -----
NEXT_PUBLIC_EXTENSION_ID=
