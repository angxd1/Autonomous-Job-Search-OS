{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env", ".env.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"],
      "env": [
        "NODE_ENV",
        "NEXT_PUBLIC_*",
        "CLERK_*",
        "DATABASE_URL",
        "DIRECT_URL",
        "OPENAI_API_KEY",
        "INNGEST_*",
        "RESEND_*",
        "SUPABASE_*",
        "ENCRYPTION_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "generate": {
      "cache": false,
      "outputs": ["node_modules/.prisma/**", "src/generated/**"]
    }
  }
}
